#!/bin/zsh
# Ghostty Agent Forge control CLI.

set -euo pipefail

typeset -U path PATH
path=(/opt/homebrew/bin /usr/local/bin /usr/bin /bin /usr/sbin /sbin $path)
export PATH

GAF_HOME="${GAF_HOME:-$HOME/.config/ghostty-agent-forge}"
GAF_STATE_DIR="${GAF_STATE_DIR:-$HOME/.local/state/ghostty-agent-forge}"
GAF_BIN_PATH="${0:A}"
GAF_BIN_DIR="${0:A:h}"

if [[ -d "${GAF_BIN_DIR:h}/zsh" && -d "${GAF_BIN_DIR:h}/scripts" ]]; then
  GAF_ROOT="${GAF_ROOT:-${GAF_BIN_DIR:h}}"
else
  GAF_ROOT="${GAF_ROOT:-$GAF_HOME}"
fi

if [[ -r "$GAF_ROOT/VERSION" ]]; then
  GAF_VERSION="${GAF_VERSION:-$(<"$GAF_ROOT/VERSION")}"
else
  GAF_VERSION="${GAF_VERSION:-0.2.1}"
fi

CONTEXTLATTICE_ORCHESTRATOR_URL="${CONTEXTLATTICE_ORCHESTRATOR_URL:-http://127.0.0.1:8075}"
CONTEXTLATTICE_PROJECT="${CONTEXTLATTICE_PROJECT:-contextlattice}"
CONTEXTLATTICE_AGENT_ID="${CONTEXTLATTICE_AGENT_ID:-ghostty_agent_forge}"

FORMULAE=(
  spaceship
  fzf
  fzf-tab
  zsh-autosuggestions
  zsh-syntax-highlighting
  zoxide
  direnv
  fd
  ripgrep
  docker
  jq
  gh
)

RESOURCE_FORMULAE=(
  btop
  procs
  smartmontools
  dust
  dua-cli
  dysk
  ncdu
  gdu
  rclone
  restic
  watchman
  hyperfine
  yq
)

COMMANDS=(
  brew
  gh
  ghostty
  jq
  rg
  fd
  zoxide
  direnv
  fzf
  docker
  orb
  python3
  node
  pnpm
  uv
  cargo
  go
)

RESOURCE_COMMANDS=(
  btop
  procs
  smartctl
  dust
  dua
  dysk
  ncdu
  gdu
  gdu-go
  rclone
  restic
  watchman
  hyperfine
  yq
  lsof
  iostat
  fs_usage
  iotop
  powermetrics
)

RESOURCE_LAUNCH_AGENT_ID="com.contextlattice.ghostty-agent-forge.resources"
RESOURCE_INTERVAL_SECS="${GAF_RESOURCE_INTERVAL_SECS:-300}"
RESOURCE_LOG_DIR="${GAF_RESOURCE_LOG_DIR:-/Volumes/wd_black/ghostty-agent-forge/resource-monitor}"
GAF_BEHAVIOR_HOME="${GAF_BEHAVIOR_HOME:-$HOME/.contextlattice/agent-packs}"
GAF_BEHAVIOR_LINK="${GAF_BEHAVIOR_LINK:-$GAF_HOME/behavior}"
GAF_PRIME_REPO="${GAF_PRIME_REPO:-sheawinkler/contextlattice-agent-prime}"
GAF_PRIME_RELEASE="${GAF_PRIME_RELEASE:-latest}"
GAF_PRIME_ALLOWED_LOGIN="${GAF_PRIME_ALLOWED_LOGIN:-sheawinkler}"
GAF_PUBLIC_REPO="${GAF_PUBLIC_REPO:-sheawinkler/ghostty-agent-forge}"
GAF_PUBLIC_REF="${GAF_PUBLIC_REF:-main}"

usage() {
  cat <<'EOF'
usage: gaf <command> [args]

Commands:
  doctor                 Check shell, tools, TCC symptoms, ContextLattice, resources.
  ensure [--yes]         Install missing Homebrew formulae from the forge contract.
  bench [runs]           Benchmark interactive zsh startup.
  resources <subcommand> Resource toolchain, snapshots, hotspots, and LaunchAgent.
  macos <subcommand>     Post-update macOS performance restore/status helpers.
  memory <subcommand>    ContextLattice memory helper.
  behavior <subcommand>  Private behavior-pack install, render, status, and doctor.
  harnesses <subcommand> Provider-neutral agent harness coverage matrix.
  codex <subcommand>     Isolated Codex account homes without duplicate binaries.
  claude <subcommand>    Claude Code permission hook install, status, and doctor.
  self <subcommand>      Inspect or update Ghostty Agent Forge itself.
  blackbox -- <cmd...>   Run a command and append structured execution telemetry.
  profile export [path]  Export this machine's terminal capability profile.
  tcc [subcommand]       Run macOS privacy/FDA doctor, targets, panes, and guide.
  rules                  Print the installed agent runtime contract.
  forge [args...]        Run the bootstrap script.
  version                Print version.

Memory subcommands:
  memory health
  memory preflight [query] [project]
  memory search <query> [project] [topic_path]
  memory pack <query> [project] [topic_path]
  memory write <file> <content> [project] [topic_path]

Resource subcommands:
  resources status
  resources snapshot [--append]
  resources tools [--missing-only]
  resources ensure [--yes]
  resources hotspots [path...]
  resources install-agent [--load] [--interval seconds] [--log-dir path]
  resources uninstall-agent

macOS subcommands:
  macos status
  macos restore [--yes] [--system]
  macos install-agent [--yes] [--load]
  macos uninstall-agent [--yes]

Behavior subcommands:
  behavior status
  behavior list
  behavior doctor
  behavior install --prime [--source path|--bundle tar.gz] [--repo owner/repo] [--release tag|latest] [--yes] [--dry-run]
  behavior render --all [--dry-run]
  behavior update [--yes|--dry-run]
  behavior rollback [version] [--yes|--dry-run]

Harness subcommands:
  harnesses status [--json]
  harnesses doctor [--json]

Codex subcommands:
  codex list
  codex status [profile|--all]
  codex add <profile> <codex-home> --yes
  codex login <profile>
  codex run <profile> [-- <codex args...>]
  codex home <profile>
  codex <profile> [codex args...]      Shorthand for codex run.

Self subcommands:
  self status
  self update [--yes|--dry-run] [--repo owner/repo] [--ref branch-or-tag]

Claude subcommands:
  claude permissions status [--claude-dir path]
  claude permissions install [--yes|--dry-run] [--claude-dir path]
  claude permissions doctor [--claude-dir path]

TCC subcommands:
  tcc status
  tcc targets
  tcc panes
  tcc open <full-disk-access|files-and-folders|accessibility|automation|developer-tools>
  tcc guide
EOF
}

log() {
  print -r -- "[gaf] $*"
}

warn() {
  print -u2 -r -- "[gaf] warn: $*"
}

have_cmd() {
  command -v "$1" >/dev/null 2>&1
}

print_check() {
  local check_status="$1"
  local label="$2"
  local value="${3:-}"
  printf "%-7s %-28s %s\n" "$check_status" "$label" "$value"
}

formula_installed() {
  local formula="$1"
  have_cmd brew && brew list --formula "$formula" >/dev/null 2>&1
}

install_missing_formulae() {
  local yes="$1"
  shift
  have_cmd brew || { print -u2 -- "Homebrew missing. Install Homebrew first."; return 1; }
  local missing=()
  local formula
  for formula in "$@"; do
    formula_installed "$formula" || missing+=("$formula")
  done
  if (( ${#missing[@]} == 0 )); then
    log "all formulae installed"
    return 0
  fi
  print -r -- "Missing formulae: ${missing[*]}"
  if (( ! yes )); then
    print -r -- "Re-run with --yes to install."
    return 2
  fi
  brew install "${missing[@]}"
}

json_escape_args() {
  python3 - "$@" <<'PY'
import json
import sys
print(json.dumps(sys.argv[1:]))
PY
}

cl_post() {
  local post_path="$1"
  local payload="${2:-}"
  if [[ -z "$payload" && ! -t 0 ]]; then
    payload="$(cat)"
  fi
  BASE_URL="$CONTEXTLATTICE_ORCHESTRATOR_URL" CL_PATH="$post_path" CL_PAYLOAD="$payload" python3 - <<'PY'
import json
import os
import urllib.request

base = os.environ["BASE_URL"].rstrip("/")
path = os.environ["CL_PATH"]
payload = os.environ["CL_PAYLOAD"]
req = urllib.request.Request(
    base + path,
    data=payload.encode("utf-8"),
    headers={"content-type": "application/json"},
    method="POST",
)
with urllib.request.urlopen(req, timeout=30) as resp:
    body = resp.read().decode("utf-8", errors="replace")
    try:
        print(json.dumps(json.loads(body), indent=2, sort_keys=True))
    except json.JSONDecodeError:
        print(body)
PY
}

doctor() {
  print "Ghostty Agent Forge doctor"
  print
  print_check "info" "version" "$GAF_VERSION"
  print_check "info" "gaf_root" "$GAF_ROOT"
  print_check "info" "gaf_home" "$GAF_HOME"
  print_check "info" "shell" "${SHELL:-unknown}"
  print_check "info" "uname" "$(uname -srm)"

  if [[ "$(uname -s)" != "Darwin" ]]; then
    print_check "warn" "platform" "expected macOS/Darwin"
  else
    print_check "ok" "platform" "$(sw_vers -productName 2>/dev/null) $(sw_vers -productVersion 2>/dev/null)"
  fi

  print
  print "Commands"
  local cmd cmd_path
  for cmd in "${COMMANDS[@]}"; do
    cmd_path="$(command -v "$cmd" 2>/dev/null || true)"
    if [[ -n "$cmd_path" ]]; then
      print_check "ok" "$cmd" "$cmd_path"
    else
      print_check "missing" "$cmd" ""
    fi
  done

  print
  print "Homebrew formulae"
  if have_cmd brew; then
    local formula
    for formula in "${FORMULAE[@]}"; do
      if formula_installed "$formula"; then
        print_check "ok" "$formula" "$(brew --prefix "$formula" 2>/dev/null || true)"
      else
        print_check "missing" "$formula" ""
      fi
    done
  else
    print_check "missing" "brew" "cannot inspect formulae"
  fi

  print
  print "Resource toolchain"
  local resource_cmd resource_cmd_path
  for resource_cmd in "${RESOURCE_COMMANDS[@]}"; do
    resource_cmd_path="$(command -v "$resource_cmd" 2>/dev/null || true)"
    if [[ -n "$resource_cmd_path" ]]; then
      print_check "ok" "$resource_cmd" "$resource_cmd_path"
    else
      print_check "missing" "$resource_cmd" ""
    fi
  done

  print
  print "Shell"
  if zsh -n "$HOME/.zshrc" >/dev/null 2>&1; then
    print_check "ok" "zshrc syntax" "$HOME/.zshrc"
  else
    print_check "fail" "zshrc syntax" "$HOME/.zshrc"
  fi
  if zsh -fc '[[ ! -o interactive ]]; source ~/.zshrc >/dev/null 2>&1 || true' >/dev/null 2>&1; then
    print_check "ok" "non_tty_load" "safe"
  else
    print_check "fail" "non_tty_load" "check ~/.zshrc"
  fi

  print
  print "TCC/FDA path probes"
  local probe
  for probe in "$HOME" "$HOME/Documents" "$HOME/Downloads" /Volumes/wd_black; do
    [[ -e "$probe" ]] || continue
    if /bin/ls "$probe" >/dev/null 2>&1; then
      print_check "ok" "$probe" "readable"
    else
      print_check "blocked" "$probe" "macOS privacy or Unix perms"
    fi
  done

  print
  print "ContextLattice"
  if curl -fsS --max-time 5 "$CONTEXTLATTICE_ORCHESTRATOR_URL/health" >/dev/null 2>&1; then
    print_check "ok" "health" "$CONTEXTLATTICE_ORCHESTRATOR_URL"
  else
    print_check "degraded" "health" "$CONTEXTLATTICE_ORCHESTRATOR_URL"
  fi

  print
  harnesses status || true

  print
  print "Resources"
  df -h "$HOME" 2>/dev/null | tail -n 1 | awk '{printf "%-7s %-28s %s used, %s available\n", "info", "home_disk", $5, $4}'
  if [[ -d /Volumes/wd_black ]]; then
    df -h /Volumes/wd_black 2>/dev/null | tail -n 1 | awk '{printf "%-7s %-28s %s used, %s available\n", "info", "wd_black_disk", $5, $4}'
  fi
  vm_stat 2>/dev/null | awk '
    /Pages free/ {gsub("\\.","",$3); free=$3}
    /Pages active/ {gsub("\\.","",$3); active=$3}
    /Pages inactive/ {gsub("\\.","",$3); inactive=$3}
    /Pages speculative/ {gsub("\\.","",$3); speculative=$3}
    END {
      if (free != "") printf "%-7s %-28s free=%s active=%s inactive=%s speculative=%s pages\n", "info", "vm_stat", free, active, inactive, speculative
    }'
}

ensure() {
  local yes=0
  while (( $# > 0 )); do
    case "$1" in
      --yes|-y) yes=1 ;;
      *) print -u2 -- "unknown ensure arg: $1"; return 2 ;;
    esac
    shift
  done
  install_missing_formulae "$yes" "${FORMULAE[@]}"
  if [[ ! -d /Applications/Ghostty.app ]]; then
    print_check "missing" "Ghostty.app" "/Applications/Ghostty.app"
    print -r -- "Install with: brew install --cask ghostty"
  else
    print_check "ok" "Ghostty.app" "/Applications/Ghostty.app"
  fi
}

resources_tools() {
  local missing_only=0
  while (( $# > 0 )); do
    case "$1" in
      --missing-only) missing_only=1 ;;
      *) print -u2 -- "unknown resources tools arg: $1"; return 2 ;;
    esac
    shift
  done

  local formula
  for formula in "${RESOURCE_FORMULAE[@]}"; do
    if formula_installed "$formula"; then
      (( missing_only )) || print_check "ok" "$formula" "$(brew --prefix "$formula" 2>/dev/null || true)"
    else
      print_check "missing" "$formula" ""
    fi
  done

  local cmd cmd_path
  for cmd in "${RESOURCE_COMMANDS[@]}"; do
    cmd_path="$(command -v "$cmd" 2>/dev/null || true)"
    if [[ -n "$cmd_path" ]]; then
      (( missing_only )) || print_check "ok" "$cmd" "$cmd_path"
    else
      print_check "missing" "$cmd" ""
    fi
  done
}

resources_ensure() {
  local yes=0
  while (( $# > 0 )); do
    case "$1" in
      --yes|-y) yes=1 ;;
      *) print -u2 -- "unknown resources ensure arg: $1"; return 2 ;;
    esac
    shift
  done
  install_missing_formulae "$yes" "${RESOURCE_FORMULAE[@]}"
}

resources_snapshot() {
  local append=0
  while (( $# > 0 )); do
    case "$1" in
      --append) append=1 ;;
      *) print -u2 -- "unknown resources snapshot arg: $1"; return 2 ;;
    esac
    shift
  done
  GAF_STATE_DIR="$GAF_STATE_DIR" GAF_RESOURCE_LOG_DIR="$RESOURCE_LOG_DIR" GAF_RESOURCE_APPEND="$append" python3 - <<'PY'
import json
import os
import re
import socket
import subprocess
from datetime import datetime, timezone
from pathlib import Path

GIB = 1024 ** 3

def run(argv, timeout=5):
    try:
        return subprocess.run(argv, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, timeout=timeout)
    except Exception as exc:
        return subprocess.CompletedProcess(argv, 124, "", str(exc))

def parse_df(targets):
    rows = []
    for target in targets:
        if not Path(target).exists():
            continue
        proc = run(["/bin/df", "-k", target], timeout=4)
        lines = [line for line in proc.stdout.splitlines() if line.strip()]
        if len(lines) < 2:
            rows.append({"target": target, "error": proc.stderr.strip() or "df_unavailable"})
            continue
        parts = lines[-1].split()
        if len(parts) < 9:
            rows.append({"target": target, "raw": lines[-1]})
            continue
        one_k_blocks, used, avail, capacity, mount = parts[1], parts[2], parts[3], parts[4], parts[-1]
        rows.append({
            "target": target,
            "mount": mount,
            "size_bytes": int(one_k_blocks) * 1024,
            "used_bytes": int(used) * 1024,
            "free_bytes": int(avail) * 1024,
            "capacity": capacity,
        })
    return rows

def parse_vm_stat():
    proc = run(["/usr/bin/vm_stat"], timeout=4)
    text = proc.stdout
    page_size = 16384
    match = re.search(r"page size of (\d+) bytes", text)
    if match:
        page_size = int(match.group(1))
    wanted = {
        "Pages free": "free_pages",
        "Pages active": "active_pages",
        "Pages inactive": "inactive_pages",
        "Pages speculative": "speculative_pages",
        "Pages throttled": "throttled_pages",
        "Pages wired down": "wired_pages",
        "Pages occupied by compressor": "compressor_pages",
        "Pageouts": "pageouts",
        "Swapins": "swapins",
        "Swapouts": "swapouts",
    }
    out = {"page_size": page_size}
    for line in text.splitlines():
        if ":" not in line:
            continue
        key, value = line.split(":", 1)
        label = wanted.get(key.strip())
        if not label:
            continue
        digits = re.sub(r"[^0-9]", "", value)
        if digits:
            out[label] = int(digits)
    return out

def parse_swap():
    proc = run(["/usr/sbin/sysctl", "vm.swapusage"], timeout=4)
    text = proc.stdout.strip()
    values = {}
    for key in ("total", "used", "free"):
        match = re.search(rf"{key}\s*=\s*([0-9.]+)([MG])", text)
        if match:
            mult = 1024 ** 2 if match.group(2) == "M" else 1024 ** 3
            values[f"{key}_bytes"] = int(float(match.group(1)) * mult)
    values["raw"] = text
    return values

def parse_ps():
    proc = run(["/bin/ps", "-axo", "pid=,ppid=,stat=,rss=,%cpu=,command="], timeout=5)
    rows = []
    states = {"zombie": 0, "stopped": 0, "uninterruptible": 0}
    for raw in proc.stdout.splitlines():
        line = raw.strip()
        if not line:
            continue
        parts = line.split(None, 5)
        if len(parts) < 6:
            continue
        pid, ppid, stat, rss, cpu, command = parts
        try:
            row = {
                "pid": int(pid),
                "ppid": int(ppid),
                "stat": stat,
                "rss_bytes": int(rss) * 1024,
                "cpu_pct": float(cpu),
                "command": command[:220],
            }
        except ValueError:
            continue
        if "Z" in stat:
            states["zombie"] += 1
        if "T" in stat:
            states["stopped"] += 1
        if "U" in stat:
            states["uninterruptible"] += 1
        rows.append(row)
    top_rss = sorted(rows, key=lambda item: item["rss_bytes"], reverse=True)[:8]
    top_cpu = sorted(rows, key=lambda item: item["cpu_pct"], reverse=True)[:8]
    return {"states": states, "top_rss": top_rss, "top_cpu": top_cpu}

def iostat_raw():
    proc = run(["/usr/sbin/iostat", "-d", "-K", "1", "2"], timeout=6)
    lines = [line.rstrip() for line in proc.stdout.splitlines() if line.strip()]
    return {"returncode": proc.returncode, "tail": lines[-6:]}

disks = parse_df(["/", "/System/Volumes/Data", str(Path.home()), "/Volumes/wd_black"])
vm = parse_vm_stat()
swap = parse_swap()
processes = parse_ps()

warnings = []
for disk in disks:
    target = disk.get("target")
    free = disk.get("free_bytes")
    if free is None:
        continue
    if target in {"/", "/System/Volumes/Data", str(Path.home())} and free < 40 * GIB:
        warnings.append(f"internal_free_below_40GiB:{target}:{round(free / GIB, 2)}GiB")
    if target == "/Volumes/wd_black" and free < 250 * GIB:
        warnings.append(f"external_free_below_250GiB:{round(free / GIB, 2)}GiB")
if not Path("/Volumes/wd_black").exists():
    warnings.append("external_volume_missing:/Volumes/wd_black")
if swap.get("used_bytes", 0) > 4 * GIB:
    warnings.append(f"swap_used_above_4GiB:{round(swap['used_bytes'] / GIB, 2)}GiB")
if processes["states"]["zombie"]:
    warnings.append(f"zombies:{processes['states']['zombie']}")
if processes["states"]["uninterruptible"]:
    warnings.append(f"uninterruptible_wait:{processes['states']['uninterruptible']}")

record = {
    "schema_version": 1,
    "ts": datetime.now(timezone.utc).isoformat(),
    "host": socket.gethostname(),
    "disks": disks,
    "vm_stat": vm,
    "swap": swap,
    "processes": processes,
    "iostat": iostat_raw(),
    "warnings": warnings,
}

if os.environ.get("GAF_RESOURCE_APPEND") == "1":
    preferred = Path(os.environ["GAF_RESOURCE_LOG_DIR"]).expanduser()
    fallback = Path(os.environ["GAF_STATE_DIR"]).expanduser() / "resources"
    preferred_parts = preferred.parts
    external_mount = None
    if preferred.is_absolute() and len(preferred_parts) >= 3 and preferred_parts[1] == "Volumes":
        external_mount = Path("/Volumes") / preferred_parts[2]
    log_dir = preferred if external_mount and external_mount.exists() else fallback
    log_dir.mkdir(parents=True, exist_ok=True)
    log_file = log_dir / f"resource-snapshots-{datetime.now(timezone.utc).strftime('%Y%m%d')}.jsonl"
    with log_file.open("a", encoding="utf-8") as fh:
        fh.write(json.dumps(record, sort_keys=True, separators=(",", ":")) + "\n")
    record["appended_to"] = str(log_file)

print(json.dumps(record, indent=2, sort_keys=True))
PY
}

resources_status() {
  local snapshot
  snapshot="$(resources_snapshot)"
  SNAPSHOT_JSON="$snapshot" python3 - <<'PY'
import json
import os
import sys

data = json.loads(os.environ["SNAPSHOT_JSON"])
print("Ghostty Agent Forge resource status")
for disk in data.get("disks", []):
    free = disk.get("free_bytes")
    used = disk.get("capacity", "?")
    if free is None:
        print(f"disk {disk.get('target')}: {disk.get('error', disk.get('raw', 'unavailable'))}")
    else:
        print(f"disk {disk.get('target')}: {used} used, {free / (1024**3):.2f} GiB free")
swap = data.get("swap", {})
if swap.get("used_bytes") is not None:
    print(f"swap: {swap['used_bytes'] / (1024**3):.2f} GiB used")
states = data.get("processes", {}).get("states", {})
print(f"process states: zombies={states.get('zombie', 0)} stopped={states.get('stopped', 0)} uninterruptible={states.get('uninterruptible', 0)}")
warnings = data.get("warnings", [])
if warnings:
    print("warnings:")
    for warning in warnings:
        print(f"  {warning}")
else:
    print("warnings: none")
PY
}

resources_hotspots() {
  local targets=("$@")
  (( ${#targets[@]} > 0 )) || targets=("$HOME" "/Volumes/wd_black")
  local target
  for target in "${targets[@]}"; do
    [[ -e "$target" ]] || { print_check "missing" "$target" ""; continue; }
    print
    print -r -- "Hotspots: $target"
    if have_cmd gdu; then
      gdu -d 1 "$target"
    elif have_cmd gdu-go; then
      gdu-go -d 1 "$target"
    elif have_cmd dust; then
      dust -d 1 "$target"
    else
      du -sh "$target"/*(N) 2>/dev/null | sort -h | tail -n 25
    fi
  done
}

resources_install_agent() {
  local load=0 dry_run=0 interval="$RESOURCE_INTERVAL_SECS" log_dir="$RESOURCE_LOG_DIR"
  while (( $# > 0 )); do
    case "$1" in
      --load) load=1 ;;
      --dry-run) dry_run=1 ;;
      --interval)
        shift
        interval="${1:-}"
        [[ "$interval" == <-> ]] || { print -u2 -- "--interval must be seconds"; return 2; }
        ;;
      --log-dir)
        shift
        log_dir="${1:-}"
        [[ -n "$log_dir" ]] || { print -u2 -- "missing path for --log-dir"; return 2; }
        ;;
      *) print -u2 -- "unknown install-agent arg: $1"; return 2 ;;
    esac
    shift
  done

  local launch_dir="$HOME/Library/LaunchAgents"
  local plist="$launch_dir/$RESOURCE_LAUNCH_AGENT_ID.plist"
  local gaf_bin="$GAF_ROOT/bin/gaf"
  [[ -x "$gaf_bin" ]] || gaf_bin="$(command -v gaf 2>/dev/null || true)"
  [[ -n "$gaf_bin" ]] || { print -u2 -- "gaf executable not found"; return 1; }
  local launch_gaf="$GAF_HOME/bin/gaf"

  if (( dry_run )); then
    print -r -- "would write $plist"
    print -r -- "program: $launch_gaf resources snapshot --append"
    print -r -- "interval: $interval"
    print -r -- "log_dir: $log_dir"
    return 0
  fi

  mkdir -p "$launch_dir" "$GAF_STATE_DIR" "$GAF_HOME/bin"
  cp "$gaf_bin" "$launch_gaf"
  chmod +x "$launch_gaf"
  gaf_bin="$launch_gaf"
  cat > "$plist" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>$RESOURCE_LAUNCH_AGENT_ID</string>
  <key>ProgramArguments</key>
  <array>
    <string>$gaf_bin</string>
    <string>resources</string>
    <string>snapshot</string>
    <string>--append</string>
  </array>
  <key>EnvironmentVariables</key>
  <dict>
    <key>GAF_RESOURCE_LOG_DIR</key>
    <string>$log_dir</string>
    <key>GAF_STATE_DIR</key>
    <string>$GAF_STATE_DIR</string>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
  </dict>
  <key>StartInterval</key>
  <integer>$interval</integer>
  <key>LowPriorityIO</key>
  <true/>
  <key>Nice</key>
  <integer>10</integer>
  <key>StandardOutPath</key>
  <string>$GAF_STATE_DIR/resource-monitor.out</string>
  <key>StandardErrorPath</key>
  <string>$GAF_STATE_DIR/resource-monitor.err</string>
</dict>
</plist>
EOF
  plutil -lint "$plist" >/dev/null
  print -r -- "$plist"
  if (( load )); then
    launchctl bootout "gui/$UID" "$plist" >/dev/null 2>&1 || true
    launchctl bootstrap "gui/$UID" "$plist"
    launchctl kickstart -k "gui/$UID/$RESOURCE_LAUNCH_AGENT_ID" >/dev/null 2>&1 || true
    log "loaded $RESOURCE_LAUNCH_AGENT_ID"
  fi
}

resources_uninstall_agent() {
  local plist="$HOME/Library/LaunchAgents/$RESOURCE_LAUNCH_AGENT_ID.plist"
  launchctl bootout "gui/$UID" "$plist" >/dev/null 2>&1 || true
  rm -f "$plist"
  log "removed $plist"
}

resources() {
  local sub="${1:-}"
  shift || true
  case "$sub" in
    status) resources_status "$@" ;;
    snapshot) resources_snapshot "$@" ;;
    tools) resources_tools "$@" ;;
    ensure) resources_ensure "$@" ;;
    hotspots) resources_hotspots "$@" ;;
    install-agent) resources_install_agent "$@" ;;
    uninstall-agent) resources_uninstall_agent "$@" ;;
    *) usage; return 2 ;;
  esac
}

behavior_current_pack() {
  if [[ -e "$GAF_BEHAVIOR_LINK" ]]; then
    print -r -- "${GAF_BEHAVIOR_LINK:A}"
    return 0
  fi
  if [[ -e "$GAF_BEHAVIOR_HOME/prime/current" ]]; then
    print -r -- "${GAF_BEHAVIOR_HOME/prime/current:A}"
    return 0
  fi
  return 1
}

behavior_helper() {
  local helper="$GAF_ROOT/scripts/behavior-pack.py"
  if [[ ! -x "$helper" ]]; then
    helper="${GAF_BIN_DIR:h}/scripts/behavior-pack.py"
  fi
  if [[ ! -x "$helper" ]]; then
    helper="$GAF_HOME/scripts/behavior-pack.py"
  fi
  [[ -x "$helper" ]] || { print -u2 -- "behavior-pack.py not found"; return 1; }
  print -r -- "$helper"
}

behavior_validate_pack() {
  local pack_dir="$1" helper
  helper="$(behavior_helper)" || return
  python3 "$helper" validate \
    --pack "$pack_dir" \
    --gaf-version "$GAF_VERSION" \
    --allowed-login "$GAF_PRIME_ALLOWED_LOGIN"
}

behavior_verify_checksum() {
  local archive="$1" sums="$2" helper
  helper="$(behavior_helper)" || return
  python3 "$helper" checksum --archive "$archive" --sums "$sums" >/dev/null
}

behavior_extract_archive() {
  local archive="$1" destination="$2" helper
  helper="$(behavior_helper)" || return
  python3 "$helper" extract --archive "$archive" --dest "$destination" >/dev/null
}

behavior_tree_digest() {
  local pack_dir="$1" helper
  helper="$(behavior_helper)" || return
  python3 "$helper" tree-digest --path "$pack_dir"
}

behavior_pack_version() {
  local pack_dir="$1"
  python3 - "$pack_dir/agent-prime-pack.json" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
with path.open("r", encoding="utf-8") as fh:
    payload = json.load(fh)
print(payload["version"])
PY
}

behavior_require_login() {
  if [[ "${GAF_BEHAVIOR_SKIP_LOGIN_CHECK:-0}" == "1" ]]; then
    return 0
  fi
  have_cmd gh || { print -u2 -- "gh is required for private behavior-pack install"; return 1; }
  local login
  login="$(gh api user -q .login 2>/dev/null || true)"
  if [[ "$login" != "$GAF_PRIME_ALLOWED_LOGIN" ]]; then
    print -u2 -- "behavior pack install requires GitHub login '$GAF_PRIME_ALLOWED_LOGIN' (current: ${login:-unknown})"
    return 1
  fi
}

behavior_atomic_link() {
  local target="$1"
  local link="$2"
  mkdir -p "${link:h}"
  if [[ ( -e "$link" || -L "$link" ) && ! -L "$link" ]]; then
    print -u2 -- "refusing to replace non-symlink path: $link"
    return 1
  fi
  python3 - "$target" "$link" <<'PY'
import os, sys
from pathlib import Path

target = sys.argv[1]
link = Path(sys.argv[2])
temporary = link.with_name(f".{link.name}.tmp-{os.getpid()}")
try:
    temporary.unlink(missing_ok=True)
    os.symlink(target, temporary)
    os.replace(temporary, link)
finally:
    temporary.unlink(missing_ok=True)
PY
}

behavior_list() {
  print "Installed Agent Prime versions"
  local current="" pack_dir version
  current="$(behavior_current_pack 2>/dev/null || true)"
  local versions=("$GAF_BEHAVIOR_HOME"/prime/<->.<->.<->(/N))
  if (( ${#versions[@]} == 0 )); then
    print_check "missing" "versions" "none"
    return 0
  fi
  for pack_dir in "${versions[@]}"; do
    version="${pack_dir:t}"
    if [[ "${pack_dir:A}" == "$current" ]]; then
      print_check "current" "$version" "$pack_dir"
    else
      print_check "installed" "$version" "$pack_dir"
    fi
  done
}

behavior_status() {
  print "Agent behavior packs"
  print
  print_check "info" "behavior_home" "$GAF_BEHAVIOR_HOME"
  print_check "info" "behavior_link" "$GAF_BEHAVIOR_LINK"

  local pack_dir=""
  if pack_dir="$(behavior_current_pack 2>/dev/null)"; then
    print_check "ok" "prime_pack" "$pack_dir"
    if [[ -f "$pack_dir/agent-prime-pack.json" ]]; then
      local version
      version="$(behavior_pack_version "$pack_dir" 2>/dev/null || true)"
      print_check "ok" "prime_version" "${version:-unknown}"
    else
      print_check "fail" "prime_manifest" "missing agent-prime-pack.json"
    fi
  else
    print_check "missing" "prime_pack" "not installed"
  fi

  print
  harnesses status || true

  print
  print "ContextLattice behavior support"
  local cmd
  for cmd in contextlattice_agent_start contextlattice_agent_policy_pack contextlattice_agent_adapter contextlattice_checkpoint; do
    if have_cmd "$cmd"; then
      print_check "ok" "$cmd" "$(command -v "$cmd")"
    else
      print_check "missing" "$cmd" ""
    fi
  done

  if have_cmd gh; then
    local login
    login="$(gh api user -q .login 2>/dev/null || true)"
    [[ "$login" == "$GAF_PRIME_ALLOWED_LOGIN" ]] \
      && print_check "ok" "github_login" "$login" \
      || print_check "warn" "github_login" "${login:-unknown}"
  else
    print_check "missing" "gh" "required for private pack updates"
  fi
}

behavior_render() {
  local dry_run=0 install=1
  while (( $# > 0 )); do
    case "$1" in
      --all) install=1 ;;
      --dry-run) dry_run=1 ;;
      *) print -u2 -- "unknown behavior render arg: $1"; return 2 ;;
    esac
    shift
  done
  local pack_dir
  pack_dir="$(behavior_current_pack)" || { print -u2 -- "prime behavior pack is not installed"; return 1; }
  local renderer="$pack_dir/scripts/render-agent-prime.py"
  [[ -x "$renderer" ]] || { print -u2 -- "renderer not executable: $renderer"; return 1; }
  local args=(--pack-root "$pack_dir" --home "$HOME" --gaf-home "$GAF_HOME" --pretty)
  (( install )) && args+=(--install)
  (( dry_run )) && args+=(--dry-run)
  python3 "$renderer" "${args[@]}"
}

behavior_install() {
  local prime=0 yes=0 dry_run=0 no_render=0 source_dir="" bundle="" repo="$GAF_PRIME_REPO" release="$GAF_PRIME_RELEASE"
  while (( $# > 0 )); do
    case "$1" in
      --prime) prime=1 ;;
      --yes|-y) yes=1 ;;
      --dry-run) dry_run=1 ;;
      --no-render) no_render=1 ;;
      --source)
        shift
        source_dir="${1:-}"
        [[ -n "$source_dir" ]] || { print -u2 -- "missing path for --source"; return 2; }
        ;;
      --bundle)
        shift
        bundle="${1:-}"
        [[ -n "$bundle" ]] || { print -u2 -- "missing path for --bundle"; return 2; }
        ;;
      --repo)
        shift
        repo="${1:-}"
        [[ -n "$repo" ]] || { print -u2 -- "missing owner/repo for --repo"; return 2; }
        ;;
      --release)
        shift
        release="${1:-}"
        [[ -n "$release" ]] || { print -u2 -- "missing tag/latest for --release"; return 2; }
        ;;
      *) print -u2 -- "unknown behavior install arg: $1"; return 2 ;;
    esac
    shift
  done
  (( prime )) || { print -u2 -- "usage: gaf behavior install --prime ..."; return 2; }
  if (( ! yes && ! dry_run )); then
    print -r -- "This installs a private behavior pack and writes managed harness blocks."
    print -r -- "Re-run with --yes to apply."
    return 2
  fi
  behavior_require_login

  local tmp_dir="" cleanup_source=0
  if [[ -n "$source_dir" ]]; then
    source_dir="${source_dir:A}"
  elif [[ -n "$bundle" ]]; then
    [[ -f "$bundle" ]] || { print -u2 -- "bundle not found: $bundle"; return 1; }
    local bundle_dir="${bundle:A:h}"
    if [[ -f "$bundle_dir/SHA256SUMS" ]]; then
      behavior_verify_checksum "${bundle:A}" "$bundle_dir/SHA256SUMS"
    else
      warn "SHA256SUMS not found next to bundle; installing explicit local bundle without checksum verification"
    fi
    tmp_dir="$(mktemp -d)"
    mkdir -p "$tmp_dir/src"
    behavior_extract_archive "${bundle:A}" "$tmp_dir/src"
    local children=("$tmp_dir"/src/*(N))
    if (( ${#children[@]} == 1 )) && [[ -d "${children[1]}" && ! -f "$tmp_dir/src/agent-prime-pack.json" ]]; then
      source_dir="${children[1]:A}"
    else
      source_dir="${tmp_dir:A}/src"
    fi
    cleanup_source=1
  else
    if (( dry_run )); then
      print -r -- "would download release $release from $repo"
      print -r -- "would verify SHA256SUMS"
      print -r -- "would install into $GAF_BEHAVIOR_HOME/prime/<version>"
      return 0
    fi
    have_cmd gh || { print -u2 -- "gh is required to download $repo"; return 1; }
    tmp_dir="$(mktemp -d)"
    mkdir -p "$tmp_dir/release" "$tmp_dir/src"
    if [[ "$release" == "latest" ]]; then
      gh release download --repo "$repo" --pattern 'contextlattice-agent-prime-*.tar.gz' --pattern 'SHA256SUMS' --dir "$tmp_dir/release"
    else
      gh release download "$release" --repo "$repo" --pattern 'contextlattice-agent-prime-*.tar.gz' --pattern 'SHA256SUMS' --dir "$tmp_dir/release"
    fi
    local archives=("$tmp_dir"/release/contextlattice-agent-prime-*.tar.gz(N))
    (( ${#archives[@]} == 1 )) || { print -u2 -- "expected one release tarball, found ${#archives[@]}"; return 1; }
    behavior_verify_checksum "$archives[1]" "$tmp_dir/release/SHA256SUMS"
    behavior_extract_archive "$archives[1]" "$tmp_dir/src"
    local children=("$tmp_dir"/src/*(N))
    if (( ${#children[@]} == 1 )) && [[ -d "${children[1]}" && ! -f "$tmp_dir/src/agent-prime-pack.json" ]]; then
      source_dir="${children[1]:A}"
    else
      source_dir="${tmp_dir:A}/src"
    fi
    cleanup_source=1
  fi
  local metadata version target tmp_target
  metadata="$(behavior_validate_pack "$source_dir")" || {
    (( cleanup_source )) && rm -rf "$tmp_dir"
    return 1
  }
  version="$(print -r -- "$metadata" | python3 -c 'import json,sys; print(json.load(sys.stdin)["version"])')"
  target="$GAF_BEHAVIOR_HOME/prime/$version"
  tmp_target="$GAF_BEHAVIOR_HOME/prime/.tmp-$version-$$"

  if (( dry_run )); then
    print -r -- "would install $source_dir -> $target"
    print -r -- "would link $GAF_BEHAVIOR_HOME/prime/current -> $target"
    print -r -- "would link $GAF_BEHAVIOR_LINK -> $GAF_BEHAVIOR_HOME/prime/current"
    (( cleanup_source )) && rm -rf "$tmp_dir"
    return 0
  fi

  mkdir -p "$GAF_BEHAVIOR_HOME/prime"
  rm -rf "$tmp_target"
  rsync -a --delete \
    --exclude .git \
    --exclude .DS_Store \
    --exclude __pycache__ \
    --exclude .pytest_cache \
    --exclude dist \
    --exclude generated \
    "$source_dir/" "$tmp_target/"
  behavior_validate_pack "$tmp_target" >/dev/null || {
    rm -rf "$tmp_target"
    (( cleanup_source )) && rm -rf "$tmp_dir"
    return 1
  }
  local incoming_digest
  incoming_digest="$(behavior_tree_digest "$tmp_target")" || {
    rm -rf "$tmp_target"
    (( cleanup_source )) && rm -rf "$tmp_dir"
    return 1
  }
  if [[ -d "$target" ]]; then
    local existing_digest
    existing_digest="$(behavior_tree_digest "$target")"
    if [[ "$existing_digest" != "$incoming_digest" ]]; then
      print -u2 -- "refusing mutable version collision for Agent Prime $version"
      rm -rf "$tmp_target"
      (( cleanup_source )) && rm -rf "$tmp_dir"
      return 1
    fi
    rm -rf "$tmp_target"
  else
    mv "$tmp_target" "$target"
  fi

  local old_current="" old_behavior=""
  [[ -L "$GAF_BEHAVIOR_HOME/prime/current" ]] && old_current="$(readlink "$GAF_BEHAVIOR_HOME/prime/current")"
  [[ -L "$GAF_BEHAVIOR_LINK" ]] && old_behavior="$(readlink "$GAF_BEHAVIOR_LINK")"
  behavior_atomic_link "$target" "$GAF_BEHAVIOR_HOME/prime/current"
  behavior_atomic_link "$GAF_BEHAVIOR_HOME/prime/current" "$GAF_BEHAVIOR_LINK"
  (( cleanup_source )) && rm -rf "$tmp_dir"
  log "installed behavior pack $version at $target"
  if (( ! no_render )); then
    if ! behavior_render --all; then
      warn "render failed; restoring previous behavior-pack links"
      if [[ -n "$old_current" ]]; then
        behavior_atomic_link "$old_current" "$GAF_BEHAVIOR_HOME/prime/current"
      else
        rm -f "$GAF_BEHAVIOR_HOME/prime/current"
      fi
      if [[ -n "$old_behavior" ]]; then
        behavior_atomic_link "$old_behavior" "$GAF_BEHAVIOR_LINK"
      else
        rm -f "$GAF_BEHAVIOR_LINK"
      fi
      if [[ -n "$old_current" ]] && ! behavior_render --all >/dev/null; then
        warn "previous behavior pack was restored but its managed blocks could not be re-rendered"
      fi
      return 1
    fi
  fi
}

behavior_doctor() {
  behavior_status
  print
  print "Behavior pack contract"
  local pack_dir metadata
  if pack_dir="$(behavior_current_pack 2>/dev/null)"; then
    if metadata="$(behavior_validate_pack "$pack_dir" 2>&1)"; then
      print_check "ok" "pack_contract" "$metadata"
    else
      print_check "fail" "pack_contract" "$metadata"
      return 1
    fi
  else
    print_check "missing" "pack_contract" "prime pack not installed"
    return 1
  fi

  print
  print "Behavior render dry run"
  local render_result
  render_result="$(mktemp "${TMPDIR:-/tmp}/gaf-behavior-render.XXXXXX")"
  if behavior_render --all --dry-run >"$render_result" \
    && python3 -m json.tool "$render_result" >/dev/null; then
    print_check "ok" "render_dry_run" "$render_result"
  else
    print_check "fail" "render_dry_run" "renderer failed or returned invalid JSON"
    rm -f "$render_result"
    return 1
  fi
  rm -f "$render_result"

  print
  harnesses doctor
}

behavior_update() {
  local yes=0 dry_run=0
  while (( $# > 0 )); do
    case "$1" in
      --yes|-y) yes=1 ;;
      --dry-run) dry_run=1 ;;
      *) print -u2 -- "unknown behavior update arg: $1"; return 2 ;;
    esac
    shift
  done
  (( dry_run )) && { behavior_install --prime --dry-run; return; }
  (( yes )) || { print -r -- "Re-run with --yes to update the private behavior pack."; return 2; }
  behavior_install --prime --yes
}

behavior_rollback() {
  local requested="" yes=0 dry_run=0
  while (( $# > 0 )); do
    case "$1" in
      --yes|-y) yes=1 ;;
      --dry-run) dry_run=1 ;;
      -*) print -u2 -- "unknown behavior rollback arg: $1"; return 2 ;;
      *)
        [[ -z "$requested" ]] || { print -u2 -- "only one rollback version may be specified"; return 2; }
        requested="$1"
        ;;
    esac
    shift
  done
  behavior_require_login
  local current current_version target version
  current="$(behavior_current_pack)" || { print -u2 -- "prime behavior pack is not installed"; return 1; }
  current_version="$(behavior_pack_version "$current")"
  if [[ -n "$requested" ]]; then
    version="$requested"
  else
    version="$(python3 - "$GAF_BEHAVIOR_HOME/prime" "$current_version" <<'PY'
import re, sys
from pathlib import Path
root = Path(sys.argv[1])
current = sys.argv[2]
current_key = tuple(map(int, current.split(".")))
versions = []
for child in root.iterdir() if root.is_dir() else ():
    if child.is_dir() and not child.is_symlink() and re.fullmatch(r"\d+\.\d+\.\d+", child.name):
        versions.append(child.name)
versions.sort(key=lambda value: tuple(map(int, value.split("."))), reverse=True)
print(next((value for value in versions if tuple(map(int, value.split("."))) < current_key), ""))
PY
)"
  fi
  [[ -n "$version" ]] || { print -u2 -- "no previous installed Agent Prime version is available"; return 1; }
  target="$GAF_BEHAVIOR_HOME/prime/$version"
  [[ -d "$target" && ! -L "$target" ]] || { print -u2 -- "rollback target is not an installed immutable version: $target"; return 1; }
  behavior_validate_pack "$target" >/dev/null
  if (( dry_run )); then
    print -r -- "would roll back Agent Prime $current_version -> $version"
    print -r -- "would render managed harness blocks from $target"
    return 0
  fi
  (( yes )) || { print -r -- "Re-run with --yes to roll back Agent Prime $current_version -> $version."; return 2; }

  local old_current="" old_behavior=""
  [[ -L "$GAF_BEHAVIOR_HOME/prime/current" ]] && old_current="$(readlink "$GAF_BEHAVIOR_HOME/prime/current")"
  [[ -L "$GAF_BEHAVIOR_LINK" ]] && old_behavior="$(readlink "$GAF_BEHAVIOR_LINK")"
  behavior_atomic_link "$target" "$GAF_BEHAVIOR_HOME/prime/current"
  behavior_atomic_link "$GAF_BEHAVIOR_HOME/prime/current" "$GAF_BEHAVIOR_LINK"
  if ! behavior_render --all; then
    warn "rollback render failed; restoring previous behavior-pack links"
    [[ -n "$old_current" ]] && behavior_atomic_link "$old_current" "$GAF_BEHAVIOR_HOME/prime/current"
    [[ -n "$old_behavior" ]] && behavior_atomic_link "$old_behavior" "$GAF_BEHAVIOR_LINK"
    if [[ -n "$old_current" ]] && ! behavior_render --all >/dev/null; then
      warn "previous behavior pack was restored but its managed blocks could not be re-rendered"
    fi
    return 1
  fi
  log "rolled back Agent Prime $current_version -> $version"
}

behavior() {
  local sub="${1:-}"
  shift || true
  case "$sub" in
    status) behavior_status "$@" ;;
    list) behavior_list "$@" ;;
    doctor) behavior_doctor "$@" ;;
    install) behavior_install "$@" ;;
    render) behavior_render "$@" ;;
    update) behavior_update "$@" ;;
    rollback) behavior_rollback "$@" ;;
    *) usage; return 2 ;;
  esac
}

bench() {
  local runs="${1:-5}"
  [[ "$runs" == <-> ]] || { print -u2 -- "runs must be integer"; return 2; }
  local i
  for i in $(seq 1 "$runs"); do
    /usr/bin/time -p zsh -ic exit >/tmp/gaf-bench.out 2>/tmp/gaf-bench.err || true
    print -r -- "startup_run=$i $(tr '\n' ' ' < /tmp/gaf-bench.err)"
  done
  rm -f /tmp/gaf-bench.out /tmp/gaf-bench.err
}

memory() {
  local sub="${1:-}"
  shift || true
  case "$sub" in
    health)
      curl -fsS --max-time 5 "$CONTEXTLATTICE_ORCHESTRATOR_URL/health"
      ;;
    preflight)
      local query="${1:-ghostty agent forge terminal visibility preflight}"
      local project="${2:-$CONTEXTLATTICE_PROJECT}"
      memory search "$query" "$project"
      ;;
    search)
      local query="${1:-}"
      local project="${2:-$CONTEXTLATTICE_PROJECT}"
      local topic_path="${3:-}"
      [[ -n "$query" ]] || { print -u2 -- "usage: gaf memory search <query> [project] [topic_path]"; return 2; }
      QUERY="$query" PROJECT="$project" TOPIC_PATH="$topic_path" AGENT_ID="$CONTEXTLATTICE_AGENT_ID" python3 - <<'PY' | cl_post "/memory/search"
import json
import os

payload = {
    "query": os.environ["QUERY"],
    "project": os.environ["PROJECT"],
    "limit": 8,
    "include_grounding": True,
    "include_retrieval_debug": True,
    "agent_id": os.environ["AGENT_ID"],
    "retrieval_mode": "fast",
}
topic_path = os.environ.get("TOPIC_PATH", "").strip()
if topic_path:
    payload["topic_path"] = topic_path
print(json.dumps(payload))
PY
      ;;
    pack)
      local query="${1:-}"
      local project="${2:-$CONTEXTLATTICE_PROJECT}"
      local topic_path="${3:-}"
      [[ -n "$query" ]] || { print -u2 -- "usage: gaf memory pack <query> [project] [topic_path]"; return 2; }
      QUERY="$query" PROJECT="$project" TOPIC_PATH="$topic_path" AGENT_ID="$CONTEXTLATTICE_AGENT_ID" python3 - <<'PY' | cl_post "/memory/context-pack"
import json
import os

payload = {
    "query": os.environ["QUERY"],
    "project": os.environ["PROJECT"],
    "include_grounding": True,
    "include_retrieval_debug": True,
    "agent_id": os.environ["AGENT_ID"],
}
topic_path = os.environ.get("TOPIC_PATH", "").strip()
if topic_path:
    payload["topic_path"] = topic_path
print(json.dumps(payload))
PY
      ;;
    write)
      local file="${1:-}"
      local content="${2:-}"
      local project="${3:-$CONTEXTLATTICE_PROJECT}"
      local topic_path="${4:-}"
      [[ -n "$file" && -n "$content" ]] || { print -u2 -- "usage: gaf memory write <file> <content> [project] [topic_path]"; return 2; }
      FILE="$file" CONTENT="$content" PROJECT="$project" TOPIC_PATH="$topic_path" python3 - <<'PY' | cl_post "/memory/write"
import json
import os

payload = {
    "projectName": os.environ["PROJECT"],
    "fileName": os.environ["FILE"],
    "content": os.environ["CONTENT"],
}
topic_path = os.environ.get("TOPIC_PATH", "").strip()
if topic_path:
    payload["topicPath"] = topic_path
print(json.dumps(payload))
PY
      ;;
    *)
      usage
      return 2
      ;;
  esac
}

blackbox() {
  if [[ "${1:-}" == "--" ]]; then
    shift
  fi
  (( $# > 0 )) || { print -u2 -- "usage: gaf blackbox -- <cmd...>"; return 2; }
  mkdir -p "$GAF_STATE_DIR"
  local log_file="$GAF_STATE_DIR/blackbox.jsonl"
  local start_ns end_ns exit_code branch argv_json
  start_ns="$(python3 - <<'PY'
import time
print(time.time_ns())
PY
)"
  branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
  argv_json="$(json_escape_args "$@")"
  set +e
  "$@"
  exit_code=$?
  set -e
  end_ns="$(python3 - <<'PY'
import time
print(time.time_ns())
PY
)"
  START_NS="$start_ns" END_NS="$end_ns" EXIT_CODE="$exit_code" BRANCH="$branch" ARGV_JSON="$argv_json" LOG_FILE="$log_file" python3 - <<'PY'
import json
import os
import socket
from datetime import datetime, timezone

record = {
    "ts": datetime.now(timezone.utc).isoformat(),
    "host": socket.gethostname(),
    "cwd": os.getcwd(),
    "branch": os.environ.get("BRANCH") or None,
    "argv": json.loads(os.environ["ARGV_JSON"]),
    "exit_code": int(os.environ["EXIT_CODE"]),
    "duration_ms": round((int(os.environ["END_NS"]) - int(os.environ["START_NS"])) / 1_000_000, 3),
    "contextlattice_url": os.environ.get("CONTEXTLATTICE_ORCHESTRATOR_URL", "http://127.0.0.1:8075"),
}
with open(os.environ["LOG_FILE"], "a", encoding="utf-8") as fh:
    fh.write(json.dumps(record, sort_keys=True) + "\n")
print(json.dumps(record, indent=2, sort_keys=True))
PY
  return "$exit_code"
}

profile_export() {
  local target="${1:-}"
  mkdir -p "$GAF_STATE_DIR"
  local tmp="${target:-$GAF_STATE_DIR/profile.json}"
  GAF_VERSION="$GAF_VERSION" GAF_ROOT="$GAF_ROOT" GAF_HOME="$GAF_HOME" python3 - <<'PY' > "$tmp"
import json
import os
import platform
import shutil
import subprocess
from datetime import datetime, timezone

commands = [
    "brew", "gh", "ghostty", "jq", "rg", "fd", "zoxide", "direnv", "fzf",
    "docker", "orb", "python3", "node", "pnpm", "uv", "cargo", "go",
    "btop", "procs", "smartctl", "dust", "dua", "dysk", "ncdu", "gdu", "gdu-go",
    "rclone", "restic", "watchman", "hyperfine", "yq",
    "lsof", "iostat", "fs_usage", "iotop", "powermetrics",
]
profile = {
    "schema_version": 1,
    "generated_at": datetime.now(timezone.utc).isoformat(),
    "gaf_version": os.environ["GAF_VERSION"],
    "gaf_root": os.environ["GAF_ROOT"],
    "gaf_home": os.environ["GAF_HOME"],
    "platform": {
        "system": platform.system(),
        "release": platform.release(),
        "machine": platform.machine(),
    },
    "shell": os.environ.get("SHELL"),
    "contextlattice": {
        "orchestrator_url": os.environ.get("CONTEXTLATTICE_ORCHESTRATOR_URL", "http://127.0.0.1:8075"),
        "agent_id": os.environ.get("CONTEXTLATTICE_AGENT_ID", "ghostty_agent_forge"),
    },
    "commands": {cmd: shutil.which(cmd) for cmd in commands},
}
try:
    profile["git"] = subprocess.check_output(["git", "remote", "-v"], text=True, stderr=subprocess.DEVNULL).splitlines()
except Exception:
    profile["git"] = []
print(json.dumps(profile, indent=2, sort_keys=True))
PY
  print -r -- "$tmp"
}

tcc() {
  if [[ -x "$GAF_ROOT/scripts/macos-tcc-doctor.zsh" ]]; then
    "$GAF_ROOT/scripts/macos-tcc-doctor.zsh" "$@"
  elif [[ -x "${GAF_BIN_DIR:h}/scripts/macos-tcc-doctor.zsh" ]]; then
    "${GAF_BIN_DIR:h}/scripts/macos-tcc-doctor.zsh" "$@"
  else
    warn "macos-tcc-doctor.zsh not found"
    doctor
  fi
}

harnesses() {
  local script="$GAF_ROOT/scripts/agent-harnesses.py"
  if [[ ! -x "$script" ]]; then
    script="${GAF_BIN_DIR:h}/scripts/agent-harnesses.py"
  fi
  if [[ ! -x "$script" ]]; then
    script="$GAF_HOME/scripts/agent-harnesses.py"
  fi
  [[ -x "$script" ]] || { print -u2 -- "agent-harnesses.py not found"; return 1; }
  (( $# > 0 )) || set -- status
  GAF_BEHAVIOR_HOME="$GAF_BEHAVIOR_HOME" \
    GAF_BEHAVIOR_LINK="$GAF_BEHAVIOR_LINK" \
    GAF_HOME="$GAF_HOME" \
    python3 "$script" "$@"
}

codex_cmd() {
  local requested_subcommand="${1:-}"
  local requested_profile="${2:-}"
  local script="$GAF_ROOT/scripts/codex-accounts.zsh"
  if [[ ! -x "$script" ]]; then
    script="${GAF_BIN_DIR:h}/scripts/codex-accounts.zsh"
  fi
  if [[ ! -x "$script" ]]; then
    script="$GAF_HOME/scripts/codex-accounts.zsh"
  fi
  [[ -x "$script" ]] || { print -u2 -- "codex-accounts.zsh not found"; return 1; }
  GAF_HOME="$GAF_HOME" "$script" "$@" || return
  if [[ "$requested_subcommand" == "add" ]] && behavior_current_pack >/dev/null 2>&1; then
    behavior_render --all >/dev/null || return
    if harnesses status --json 2>/dev/null | PROFILE="$requested_profile" python3 -c '
import json, os, sys
profile_id = "codex-profile-" + os.environ["PROFILE"]
payload = json.load(sys.stdin)
raise SystemExit(0 if any(
    item.get("id") == profile_id and item.get("policy_state") == "current"
    for item in payload.get("harnesses", [])
) else 1)
'
    then
      log "rendered Agent Prime into Codex profile '$requested_profile'"
    else
      warn "the installed behavior pack did not project into Codex profile '$requested_profile'; update Agent Prime"
      return 1
    fi
  fi
}

self_cmd() {
  local script="$GAF_ROOT/scripts/self-update.zsh"
  if [[ ! -x "$script" ]]; then
    script="${GAF_BIN_DIR:h}/scripts/self-update.zsh"
  fi
  if [[ ! -x "$script" ]]; then
    script="$GAF_HOME/scripts/self-update.zsh"
  fi
  [[ -x "$script" ]] || { print -u2 -- "self-update.zsh not found"; return 1; }
  GAF_VERSION="$GAF_VERSION" \
    GAF_PUBLIC_REPO="$GAF_PUBLIC_REPO" \
    GAF_PUBLIC_REF="$GAF_PUBLIC_REF" \
    GAF_CALLER_BIN="$GAF_BIN_PATH" \
    "$script" "$@"
}

claude_cmd() {
  local sub="${1:-}"
  shift || true
  case "$sub" in
    permissions)
      local script="$GAF_ROOT/scripts/claude-permissions.zsh"
      if [[ ! -x "$script" ]]; then
        script="${GAF_BIN_DIR:h}/scripts/claude-permissions.zsh"
      fi
      if [[ ! -x "$script" ]]; then
        script="$GAF_HOME/scripts/claude-permissions.zsh"
      fi
      [[ -x "$script" ]] || { print -u2 -- "claude-permissions.zsh not found"; return 1; }
      "$script" "$@"
      ;;
    *) usage; return 2 ;;
  esac
}

macos() {
  local script="$GAF_ROOT/scripts/macos-performance-restore.zsh"
  if [[ ! -x "$script" ]]; then
    script="${GAF_BIN_DIR:h}/scripts/macos-performance-restore.zsh"
  fi
  if [[ ! -x "$script" ]]; then
    script="$GAF_HOME/scripts/macos-performance-restore.zsh"
  fi
  [[ -x "$script" ]] || { print -u2 -- "macos-performance-restore.zsh not found"; return 1; }
  "$script" "$@"
}

rules() {
  local contract="$GAF_ROOT/config/agent-runtime.json"
  [[ -f "$contract" ]] || contract="$GAF_HOME/agent-runtime.json"
  [[ -f "$contract" ]] || { print -u2 -- "agent-runtime.json not found"; return 1; }
  cat "$contract"
}

forge() {
  if [[ -x "$GAF_ROOT/scripts/bootstrap-ghostty-agent-forge.zsh" ]]; then
    "$GAF_ROOT/scripts/bootstrap-ghostty-agent-forge.zsh" "$@"
  elif [[ -x "${GAF_BIN_DIR:h}/scripts/bootstrap-ghostty-agent-forge.zsh" ]]; then
    "${GAF_BIN_DIR:h}/scripts/bootstrap-ghostty-agent-forge.zsh" "$@"
  else
    print -u2 -- "bootstrap script not found"
    return 1
  fi
}

case "${1:-}" in
  doctor) shift; doctor "$@" ;;
  ensure) shift; ensure "$@" ;;
  bench) shift; bench "$@" ;;
  resources) shift; resources "$@" ;;
  macos) shift; macos "$@" ;;
  memory) shift; memory "$@" ;;
  behavior) shift; behavior "$@" ;;
  harnesses|agents) shift; harnesses "$@" ;;
  codex) shift; codex_cmd "$@" ;;
  claude) shift; claude_cmd "$@" ;;
  self) shift; self_cmd "$@" ;;
  blackbox) shift; blackbox "$@" ;;
  profile)
    shift
    case "${1:-}" in
      export) shift; profile_export "$@" ;;
      *) usage; exit 2 ;;
    esac
    ;;
  tcc) shift; tcc "$@" ;;
  rules) shift; rules "$@" ;;
  forge) shift; forge "$@" ;;
  version|-v|--version) print "$GAF_VERSION" ;;
  -h|--help|"") usage ;;
  *) print -u2 -- "unknown command: $1"; usage; exit 2 ;;
esac
